    "@vsnap/session": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "tsdown": "^0.15.4",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "vitest": ">=4 <5"
  }
}
