{
  "name": "@vsnap/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./environment": "./dist/environment.js"
  },
  "scripts": {
    "build": "tsdown --dts --sourcemap src/index.ts src/environment.ts",
